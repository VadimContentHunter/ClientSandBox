<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net10.0-windows</TargetFramework>
		<Nullable>enable</Nullable>
		<UseWindowsForms>true</UseWindowsForms>
		<ImplicitUsings>enable</ImplicitUsings>
		<ApplicationManifest>app.manifest</ApplicationManifest>
		<ApplicationIcon>Assets\ClientSandBox.ico</ApplicationIcon>
		<AssemblyName>ClientSandBox</AssemblyName>
		<Product>ClientSandBox</Product>
		<Company>VadimContentHunter</Company>
		<Authors>VadimContentHunter</Authors>
		<Description>ClientSandBox for sing-box management.</Description>
		<Version>1.0.0</Version>
		<AssemblyVersion>1.0.0.0</AssemblyVersion>
		<FileVersion>1.0.0.0</FileVersion>
		<InformationalVersion>1.0.0</InformationalVersion>
		<IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
	</PropertyGroup>
	
	<ItemGroup>
		<PackageReference Include="System.ServiceProcess.ServiceController" Version="10.0.9" />
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="SystemProxy\" />
	  <Folder Include="Installer\" />
	</ItemGroup>

</Project>